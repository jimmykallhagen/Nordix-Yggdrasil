[Desktop Entry]
Name=Wine Windows Program Loader
Comment=Run Windows programs with Wine
Exec=wine %f
Terminal=false
Type=Application
Icon=wine
MimeType=application/x-ms-dos-executable;application/x-msdos-program;application/x-msdownload;application/x-exe;application/x-win-exe;application/x-dosexec;
Categories=System;
NoDisplay=true
