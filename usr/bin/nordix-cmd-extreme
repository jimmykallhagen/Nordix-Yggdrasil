#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (c) 2025 Nordix
#
# This configuration is part of Nordix Linux

 if [[ $EUID -ne 0 ]]; then
     echo "This script must be run as root (sudo)"
     exit 1
 fi

 echo "
  ######*************************************************#####
 ###                                                        ###
##                                                            ##
 # * * Nordix commandline collection - CPU Flags: Extreme * * #
##                                                            ##
 ###                                                        ###
  ######*************************************************#####
"
sleep 2
ROOT_DATASET=$(zfs list -H -o name,mountpoint | grep -E '\s/$' | cut -f1)
LAST_CPU=$(($(nproc) - 1))

echo "nohz_full=2-${LAST_CPU}"
sleep 2

zfs set org.zfsbootmenu:commandline="rw boot=zfs nowatchdog split_lock_detect=off mitigations=off \
processor.max_cstate=1 amd_pstate=active idle=nomwait zswap.enabled=0 transparent_hugepage=madvise \
clocksource=tsc tsc=reliable hpet=disable nohz=on nohz_full=2-${LAST_CPU} highres=on threadirqs skew_tick=1 splash loglevel=3 \
snd_hda_intel.power_save=0 snd_hda_intel.power_save_controller=N" ${ROOT_DATASET} 

echo "New commandline flags applied"
sleep 1 
echo "Zfsbootmenu is armed and ready, do you dare to boot?"
