# ==========================================================================
# Nordix Dynamic Theme — kdeglobals (pywal template)
# ==========================================================================
# Place in: ~/.config/wal/templates/kdeglobals
# Output:   ~/.cache/wal/kdeglobals
#
# This template is for Qt apps that read ~/.config/kdeglobals instead of
# the .colors file. It uses the same color mapping as nordix-dynamic.colors
# and the GTK3/GTK4 templates:
#
#   color1  = accent / destructive / red
#   color2  = success / green
#   color3  = warning / yellow
#   color4  = link / blue
#   color5  = visited / purple
#   color8  = muted / inactive
#   color9  = bright red (intense variant of color1)
#
# nordix-dynamic-theme.py symlinks ~/.cache/wal/kdeglobals
# to ~/.config/kdeglobals so all Qt apps pick up pywal colors.
# ==========================================================================

